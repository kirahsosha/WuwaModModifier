<Window x:Class="WuwaModModifier.VersionSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WuwaModModifier.ViewModels"
        mc:Ignorable="d"
        Title="版本更新同步"
        Height="840"
        Width="1460"
        MinHeight="760"
        MinWidth="1280"
        Background="#FFFAF7F1"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="版本更新同步"
                           Style="{StaticResource SectionTitleStyle}"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource InsetBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="已导入角色目录"
                                       FontWeight="SemiBold"/>
                            <TextBox Margin="0,6,0,0"
                                     IsReadOnly="True"
                                     Text="{Binding ImportedModDirectoryPath, Mode=OneWay}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="此目录仅从主窗口当前选中的角色目录导入；如需切换，请关闭窗口后回到主窗口重新选择角色目录。"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="4"
                           Text="{Binding StatusText}"
                           Style="{StaticResource CaptionTextStyle}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="446"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"
                                              MinWidth="140"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="自动配对作业"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding CandidateSummaryText}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="手动配对"
                                IsEnabled="{Binding CanOpenManualPairing}"
                                Click="btnAddManualPairing_Click"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Grid.Column="4"
                                Content="刷新配对"
                                Command="{Binding RefreshCurrentPairingsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="列表筛选"/>
                        <ComboBox Grid.Column="1"
                                  Margin="8,0,0,0"
                                  SelectedValue="{Binding SelectedJobFilterMode}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="全部作业"
                                          Tag="{x:Static vm:VersionSyncJobFilterMode.All}"/>
                            <ComboBoxItem Content="仅看有差异"
                                          Tag="{x:Static vm:VersionSyncJobFilterMode.HasDifferences}"/>
                            <ComboBoxItem Content="仅看需人工确认"
                                          Tag="{x:Static vm:VersionSyncJobFilterMode.ManualReviewOnly}"/>
                            <ComboBoxItem Content="仅看可自动应用"
                                          Tag="{x:Static vm:VersionSyncJobFilterMode.AutoApplicableOnly}"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Text="批量策略"/>
                        <ComboBox Grid.Column="4"
                                  Margin="8,0,0,0"
                                  SelectedValue="{Binding SelectedBatchApplyMode}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="应用全部差异项"
                                          Tag="{x:Static vm:VersionSyncBatchApplyMode.AllVisibleJobs}"/>
                            <ComboBoxItem Content="只应用可自动项"
                                          Tag="{x:Static vm:VersionSyncBatchApplyMode.AutoApplicableOnly}"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Text="{Binding BatchApplyModeDescriptionText}"
                               Style="{StaticResource CaptionTextStyle}"/>

                    <DataGrid Grid.Row="6"
                              ItemsSource="{Binding PairingJobs}"
                              SelectedItem="{Binding SelectedPairingJob, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              PreviewMouseRightButtonDown="PairingJobsGrid_PreviewMouseRightButtonDown">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="交换配对"
                                          Command="{Binding PlacementTarget.DataContext.SwapSelectedPairingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="删除配对"
                                          Command="{Binding PlacementTarget.DataContext.DeleteSelectedPairingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Job.OldCandidate.Id}"
                                                Width="96"/>
                            <DataGridTextColumn Header="状态"
                                                Binding="{Binding StatusText}"
                                                Width="120"/>
                            <DataGridTextColumn Header="差异摘要"
                                                Binding="{Binding DifferenceCount}"
                                                Width="84"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource InsetBorderStyle}"
                            Background="{StaticResource AccentSoftBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="当前对比预览"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedJobSummaryText}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ComparisonSummaryText}"
                                           Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="按键和参数的“预览结果”列可编辑；点击“同步结构化编辑”会把结构化修改和右侧同步预览中的手工改动一起提交到新版文本并刷新对比。需要落盘时再点“保存新版文本”。"
                                           Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <Button Content="同步结构化编辑"
                                        Command="{Binding ApplyStructuredPreviewEditsCommand}"
                                        Style="{StaticResource BaseButtonStyle}"/>
                                <Button Content="保存新版文本"
                                        Command="{Binding SaveNewConfigTextCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,8,0,0"/>
                                <Button Content="应用当前作业"
                                        Command="{Binding ApplySelectedJobCommand}"
                                        Style="{StaticResource WarmButtonStyle}"
                                        Margin="0,8,0,0"/>
                                <Button Margin="0,8,0,0"
                                        Content="应用全部作业"
                                        Command="{Binding ApplyAllJobsCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2">
                        <TabItem Header="按键对比">
                            <DataGrid Margin="6"
                                      ItemsSource="{Binding ToggleDiffItems}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      PreviewMouseRightButtonDown="SyncableDiffGrid_PreviewMouseRightButtonDown"
                                      ContextMenuOpening="SyncableDiffGrid_ContextMenuOpening">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="同步"
                                                  Command="{Binding PlacementTarget.DataContext.SyncToggleDiffItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Visibility="{Binding PlacementTarget.SelectedItem.CanSyncPreview, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="节名"
                                                        Binding="{Binding SectionName}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="旧按键"
                                                        Binding="{Binding OldKeyBindingsText}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="新按键"
                                                        Binding="{Binding NewKeyBindingsText}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="旧目标值"
                                                        Binding="{Binding OldTargetValuesText}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="新目标值"
                                                        Binding="{Binding NewTargetValuesText}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="预览结果"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ResultKeyBindingsText}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ResultKeyBindingsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="预览目标值"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ResultTargetValuesText}"
                                                           TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ResultTargetValuesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinLines="2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="状态"
                                                        Binding="{Binding Status}"
                                                        Width="120"
                                                        IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="参数对比">
                            <DataGrid Margin="6"
                                      ItemsSource="{Binding ParameterDiffItems}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      PreviewMouseRightButtonDown="SyncableDiffGrid_PreviewMouseRightButtonDown"
                                      ContextMenuOpening="SyncableDiffGrid_ContextMenuOpening">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="同步"
                                                  Command="{Binding PlacementTarget.DataContext.SyncParameterDiffItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Visibility="{Binding PlacementTarget.SelectedItem.CanSyncPreview, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="参数"
                                                        Binding="{Binding Name}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="旧默认值"
                                                        Binding="{Binding OldDefaultValue}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTextColumn Header="新默认值"
                                                        Binding="{Binding NewDefaultValue}"
                                                        Width="*"
                                                        IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="预览结果"
                                                            Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ResultDefaultValue}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ResultDefaultValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="状态"
                                                        Binding="{Binding Status}"
                                                        Width="120"
                                                        IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="模型对比">
                            <DataGrid Margin="6"
                                      ItemsSource="{Binding VisibilityDiffItems}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      PreviewMouseRightButtonDown="SyncableDiffGrid_PreviewMouseRightButtonDown"
                                      ContextMenuOpening="SyncableDiffGrid_ContextMenuOpening">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="同步"
                                                  Command="{Binding PlacementTarget.DataContext.SyncVisibilityDiffItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Visibility="{Binding PlacementTarget.SelectedItem.CanSyncPreview, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="模型项"
                                                        Binding="{Binding DisplayText}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="旧绑定"
                                                        Binding="{Binding OldBindingText}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="新绑定"
                                                        Binding="{Binding NewBindingText}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="预览结果"
                                                        Binding="{Binding ResultBindingText}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="状态"
                                                        Binding="{Binding Status}"
                                                        Width="120"/>
                                    <DataGridTextColumn Header="说明"
                                                        Binding="{Binding Detail}"
                                                        Width="1.4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="文本对比">
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Row="0"
                                      Grid.ColumnSpan="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="104"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="104"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="btnPreviousDifference"
                                            AutomationProperties.Name="上一个差异"
                                            AutomationProperties.HelpText="跳转到上一个配置差异位置"
                                            Grid.Column="0"
                                            MinWidth="88"
                                            Padding="12,4"
                                            Content="上一个"
                                            Click="btnPreviousDifference_Click"/>
                                    <Button x:Name="btnNextDifference"
                                            AutomationProperties.Name="下一个差异"
                                            AutomationProperties.HelpText="跳转到下一个配置差异位置"
                                            Grid.Column="2"
                                            MinWidth="88"
                                            Padding="12,4"
                                            Content="下一个"
                                            Click="btnNextDifference_Click"/>
                                    <Button x:Name="btnApplyOldDifference"
                                            AutomationProperties.Name="应用旧配置"
                                            AutomationProperties.HelpText="将当前差异行的旧版本内容应用到结果中"
                                            Grid.Column="4"
                                            Width="104"
                                            Padding="12,4"
                                            Content="应用旧配置"
                                            Click="btnApplyOldDifference_Click"
                                            IsEnabled="False"/>
                                    <Button x:Name="btnApplyNewDifference"
                                            AutomationProperties.Name="应用新配置"
                                            AutomationProperties.HelpText="将当前差异行的新版本内容应用到结果中"
                                            Grid.Column="6"
                                            Width="104"
                                            Padding="12,4"
                                            Content="应用新配置"
                                            Click="btnApplyNewDifference_Click"
                                            IsEnabled="False"/>
                                    <TextBlock x:Name="txtDifferencePosition"
                                               Grid.Column="8"
                                               Margin="0,4,0,0"
                                               VerticalAlignment="Center"
                                               Text="无差异"
                                               Style="{StaticResource CaptionTextStyle}"/>
                                </Grid>

                                <Border Grid.Row="2"
                                        Grid.Column="0"
                                        Style="{StaticResource InsetBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="旧配置文本"
                                                   FontWeight="SemiBold"/>
                                        <RichTextBox x:Name="rtbOldConfigText"
                                                     Grid.Row="2"
                                                     IsReadOnly="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     SpellCheck.IsEnabled="False"
                                                     PreviewMouseLeftButtonDown="ComparisonEditor_PreviewMouseLeftButtonDown"
                                                     GotKeyboardFocus="ComparisonEditor_GotKeyboardFocus"
                                                     SelectionChanged="ComparisonEditor_SelectionChanged"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource InsetBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="新版原始文本"
                                                   FontWeight="SemiBold"/>
                                        <RichTextBox x:Name="rtbNewConfigText"
                                                     Grid.Row="2"
                                                     IsReadOnly="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     SpellCheck.IsEnabled="False"
                                                     PreviewMouseLeftButtonDown="ComparisonEditor_PreviewMouseLeftButtonDown"
                                                     GotKeyboardFocus="ComparisonEditor_GotKeyboardFocus"
                                                     SelectionChanged="ComparisonEditor_SelectionChanged"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Grid.Column="4"
                                        Style="{StaticResource InsetBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="同步预览文本"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="0"
                                                   Margin="92,1,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="可直接编辑并应用。"
                                                   Style="{StaticResource CaptionTextStyle}"/>
                                        <RichTextBox x:Name="rtbResultConfigText"
                                                     Grid.Row="2"
                                                     IsReadOnly="False"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     SpellCheck.IsEnabled="False"
                                                     PreviewMouseLeftButtonDown="ComparisonEditor_PreviewMouseLeftButtonDown"
                                                     GotKeyboardFocus="ComparisonEditor_GotKeyboardFocus"
                                                     SelectionChanged="ComparisonEditor_SelectionChanged"
                                                     TextChanged="rtbResultConfigText_TextChanged"
                                                     LostFocus="rtbResultConfigText_LostFocus"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource InsetBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="96"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding LastApplyText}"
                           Style="{StaticResource CaptionTextStyle}"/>
                <TextBlock Grid.Row="2"
                           Text="{Binding BatchApplySummaryText}"
                           Style="{StaticResource CaptionTextStyle}"/>
                <TextBox Grid.Row="4"
                         Text="{Binding BatchApplyLogText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"/>
            </Grid>
        </Border>
    </Grid>
</Window>