<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Window background ── -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#FFFBF6EF"
                      Offset="0"/>
        <GradientStop Color="#FFFAFCFC"
                      Offset="0.58"/>
        <GradientStop Color="#FFF4F7F4"
                      Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Panel / surface brushes ── -->
    <SolidColorBrush x:Key="HeroPanelBrush"
                     Color="#FFFBF7F1"/>
    <SolidColorBrush x:Key="CardBrush"
                     Color="#FFFFFEFC"/>
    <SolidColorBrush x:Key="InsetPanelBrush"
                     Color="#FFFBFCFC"/>
    <SolidColorBrush x:Key="HeaderPanelBrush"
                     Color="#FFF3F7F8"/>

    <!-- ── Accent palette ── -->
    <SolidColorBrush x:Key="AccentBrush"
                     Color="#FF1F6B68"/>
    <SolidColorBrush x:Key="AccentDarkBrush"
                     Color="#FF114847"/>
    <SolidColorBrush x:Key="AccentSoftBrush"
                     Color="#FFDDEFEB"/>

    <!-- ── Warm / gold palette ── -->
    <SolidColorBrush x:Key="WarmBrush"
                     Color="#FFBD6C3E"/>
    <SolidColorBrush x:Key="WarmDarkBrush"
                     Color="#FF944E24"/>
    <SolidColorBrush x:Key="WarmSoftBrush"
                     Color="#FFF7E4D6"/>
    <SolidColorBrush x:Key="GoldSoftBrush"
                     Color="#FFF6ECCB"/>

    <!-- ── Text / line brushes ── -->
    <SolidColorBrush x:Key="InkBrush"
                     Color="#FF193448"/>
    <SolidColorBrush x:Key="MutedTextBrush"
                     Color="#FF617282"/>
    <SolidColorBrush x:Key="LineBrush"
                     Color="#FFD6E1E6"/>
    <SolidColorBrush x:Key="SoftLineBrush"
                     Color="#FFEAF0F2"/>

    <!-- ── Disabled state brushes ── -->
    <SolidColorBrush x:Key="DisabledBrush"
                     Color="#FFE4E8EB"/>
    <SolidColorBrush x:Key="DisabledTextBrush"
                     Color="#FF94A0AA"/>

    <!-- ── Effects ── -->
    <DropShadowEffect x:Key="SoftShadowEffect"
                      BlurRadius="16"
                      ShadowDepth="0"
                      Opacity="0.08"
                      Color="#FF32495B"/>

</ResourceDictionary>
