<Window x:Class="WuwaModModifier.ManualPairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手动配对"
        Height="320"
        Width="760"
        MinHeight="280"
        MinWidth="640"
        Background="#FFFAF7F1"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="手动选择旧版和新版目录"
                   FontFamily="Bahnschrift"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#FF193448"/>

        <TextBlock Grid.Row="2"
                   Text="手动配对会按你选择的旧版和新版目录立即生成一次预览，并加入当前作业列表。若与现有配对冲突，会用新的手动配对替换旧项。"
                   TextWrapping="Wrap"
                   Foreground="#FF617282"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="旧版目录"
                           FontWeight="SemiBold"
                           Foreground="#FF193448"/>
                <ComboBox x:Name="cmbOldCandidate"
                          Margin="0,6,0,0"
                          MinHeight="34"
                          ItemsSource="{Binding Candidates}"
                          SelectedItem="{Binding SelectedOldCandidate}"
                          DisplayMemberPath="DisplayText"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="新版目录"
                           FontWeight="SemiBold"
                           Foreground="#FF193448"/>
                <ComboBox x:Name="cmbNewCandidate"
                          Margin="0,6,0,0"
                          MinHeight="34"
                          ItemsSource="{Binding Candidates}"
                          SelectedItem="{Binding SelectedNewCandidate}"
                          DisplayMemberPath="DisplayText"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="96"
                    Margin="0,0,8,0"
                    Content="取消"
                    IsCancel="True"/>
            <Button Width="112"
                    Content="分析并加入"
                    IsDefault="True"
                    Command="{Binding ConfirmCommand}"
                    Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>