<Window x:Class="WuwaModModifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WuwaModModifier"
        xmlns:vm="clr-namespace:WuwaModModifier.ViewModels"
        xmlns:data="clr-namespace:WuwaModModifier.Data.ViewModels"
        mc:Ignorable="d"
        Title="WuwaModModifier" Height="600" Width="800">
    <Border Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Height="26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lblModPath" Content="Mod目录：" Grid.Column="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                <TextBox x:Name="txtModPath" Grid.Column="1" Margin="0 0 10 0" Text="{Binding ModFolderPath, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                <Button x:Name="btnModPath" Content="读取Mod目录" Grid.Column="2" Command="{Binding BtnModPathCommand}"/>
            </Grid>
            <Grid Grid.Row="1" Margin="0 10 0 0" Height="26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lblWwmiPath" Content="WWMI目录：" Grid.Column="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                <TextBox x:Name="txtWwmiPath" Grid.Column="1" Margin="0,0,10,0" Text="{Binding WwmiFolderPath, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                <Button x:Name="btnWwmiPath" Content="读取WWMI目录" Grid.Column="2" Command="{Binding BtnWwmiPathCommand}"></Button>
            </Grid>
            <Grid Grid.Row="2" Margin="0 10 0 0" Height="26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="cbxIgnoreWeapon" Content="忽略武器MOD" Grid.Column="1" Margin="10 0 0 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsChecked="{Binding IgnoreWeapon}"/>
                <CheckBox x:Name="cbxIgnoreOther" Content="忽略Other文件夹" Grid.Column="2" Margin="10 0 0 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsChecked="{Binding IgnoreOther}"/>
                <Button x:Name="btnLoadSelectedMods" Content="加载已选择MOD" Grid.Column="3" Margin="10 0 0 0" Command="{Binding BtnLoadSelectedModsCommand}"></Button>
                <Button x:Name="btnRandomLoadAllMods" Content="随机加载MOD" Grid.Column="4" Margin="10 0 0 0" Command="{Binding BtnRandomLoadAllModsCommand}" ></Button>
                <Button x:Name="btnClearAllMods" Content="清空已加载MOD" Grid.Column="5" Margin="10 0 0 0" Command="{Binding BtnClearAllModsCommand}"></Button>
            </Grid>
            <TreeView x:Name="tvModDirectory"
                      Grid.Row="3"
                      Margin="0 10 0 0"
                      ItemsSource="{Binding DirectoryItems}"
                      PreviewMouseRightButtonDown="tvModDirectory_PreviewMouseRightButtonDown">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type data:DirectoryItemViewModel}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <!-- ContextMenu 的 DataContext 不是 TreeView，所以通过 TreeView.DataContext 找命令 -->
                                <ContextMenu>
                                    <MenuItem Header="打开MOD文件夹"
                                              Command="{Binding DataContext.OpenModFolderCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Grid>
    </Border>
</Window>
